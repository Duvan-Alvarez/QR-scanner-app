# Example environment variables for production
NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1

# Path inside container (docker-compose mounts ./data -> /app/data)
DATABASE_PATH=/app/data/database.sqlite

# Initial users created only when they do not already exist.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-admin
DEFAULT_SCANNER_USERNAME=scanner
DEFAULT_SCANNER_PASSWORD=change-me-scanner
